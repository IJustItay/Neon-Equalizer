{
  "name": "neon-equalizer",
  "version": "2.4.0",
  "description": "Professional Neon Equalizer GUI for Equalizer APO with AutoEQ and Squiglink integration",
  "keywords": [
    "equalizer-apo",
    "equalizer",
    "parametric-eq",
    "graphic-eq",
    "autoeq",
    "squiglink",
    "headphone-eq",
    "audio-dsp",
    "vst-plugins",
    "loudness-correction",
    "windows",
    "electron",
    "desktop-app",
    "portable-app",
    "iem-tuning",
    "speaker-correction",
    "audio-preview",
    "eq-presets"
  ],
  "author": "Itay",
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=22.12",
    "pnpm": ">=9"
  },
  "homepage": "https://github.com/IJustItay/Neon-Equalizer#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/IJustItay/Neon-Equalizer.git"
  },
  "bugs": {
    "url": "https://github.com/IJustItay/Neon-Equalizer/issues"
  },
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "icons": "node scripts/generate-icons.mjs",
    "build": "vite build",
    "dist": "node scripts/generate-icons.mjs && vite build && electron-builder --win",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "build": {
    "appId": "com.neonequalizer.app",
    "productName": "Neon Equalizer",
    "copyright": "Copyright © 2025",
    "directories": {
      "output": "release",
      "buildResources": "assets"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "IJustItay",
        "repo": "Neon-Equalizer",
        "releaseType": "release"
      }
    ],
    "files": [
      "dist/**/*",
      "electron/**/*",
      "assets/**/*",
      "package.json"
    ],
    "win": {
      "icon": "assets/icon.ico",
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "requestedExecutionLevel": "requireAdministrator"
    },
    "portable": {
      "artifactName": "Neon-Equalizer-${version}-Portable.exe",
      "requestExecutionLevel": "admin"
    },
    "nsis": {
      "include": "build/installer.nsh",
      "artifactName": "Neon-Equalizer-${version}-Setup.exe",
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    }
  },
  "devDependencies": {
    "concurrently": "^9.0.0",
    "electron": "^41.0.0",
    "electron-builder": "^26.8.1",
    "sharp": "^0.34.5",
    "vite": "^6.0.0",
    "vitest": "^3.2.6",
    "wait-on": "^8.0.0"
  },
  "dependencies": {
    "adm-zip": "^0.6.0",
    "electron-updater": "^6.8.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "electron-builder",
      "esbuild",
      "sharp"
    ],
    "overrides": {
      "shell-quote@<1.8.4": ">=1.8.4"
    }
  }
}
