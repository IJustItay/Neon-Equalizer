# pnpm configuration (Neon Equalizer)
# Use pnpm, not npm — run `corepack pnpm install`.

# Enforce the Node/pnpm versions declared in package.json > engines.
engine-strict=true

# Convenience for a single-package repo.
auto-install-peers=true
strict-peer-dependencies=false

# electron-builder traverses node_modules expecting a flat (npm-style) layout;
# pnpm's default isolated store breaks packaging. Hoist to a flat node_modules.
node-linker=hoisted

# Supply-chain hardening: install/build lifecycle scripts run ONLY for the
# packages allowlisted in package.json > pnpm.onlyBuiltDependencies. Every other
# dependency is installed without executing its scripts, which neutralizes the
# common "malicious postinstall" npm worm vector.
